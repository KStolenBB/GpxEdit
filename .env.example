# =============================
# Backend (FastAPI)
# =============================

# PostgreSQL / PostGIS connection
DATABASE_URL=postgresql://postgres:secret@localhost:5432/gpxedit

# JWT auth
JWT_SECRET_KEY=change-me-in-local-dev
JWT_EXPIRES_MINUTES=480

# GPX import limits
GPX_MAX_FILE_SIZE_MB=10
GPX_MAX_POINTS=50000

# Elevation enrichment
ELEVATION_THRESHOLD_M=2
ELEVATION_LOOKUP_MAX_POINTS=1000

# CORS/frontend origin
FRONTEND_ORIGIN=http://localhost:5173

# Kartverket integration endpoints (backend)
KARTVERKET_ELEVATION_BASE_URL=https://ws.geonorge.no/hoydedata/v1
KARTVERKET_PLACE_SEARCH_BASE_URL=https://ws.geonorge.no/stedsnavn/v1


# =============================
# Frontend (Vite + React)
# =============================

# Backend API base URL
VITE_API_BASE_URL=http://localhost:8000

# Keep this aligned with ELEVATION_THRESHOLD_M
VITE_ELEVATION_THRESHOLD_M=2

# Kartverket map tiles
VITE_KARTVERKET_TOPO_TILE_URL=https://cache.kartverket.no/topo/v1/wmts/1.0.0/topo/default/webmercator/{z}/{y}/{x}.png
VITE_KARTVERKET_ORTHO_TILE_URL=https://cache.kartverket.no/nib/v1/wmts/1.0.0/nib/default/webmercator/{z}/{y}/{x}.png
